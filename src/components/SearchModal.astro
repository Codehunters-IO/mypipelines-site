---
import { t, type Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

{/* Trigger — opens the Cmd+K search dialog */}
<button
  type="button"
  data-search-open
  aria-haspopup="dialog"
  aria-label={t(lang, 'search.openAriaLabel')}
  class="group inline-flex items-center gap-2 rounded-md border border-[var(--border-subtle)] bg-[var(--surface-sunken)] px-2 py-1 text-sm text-[var(--fg-muted)] transition-colors hover:text-[var(--fg)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
>
  <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="9" cy="9" r="6"></circle>
    <path d="m14 14 4 4" stroke-linecap="round"></path>
  </svg>
  <span class="hidden sm:inline">{t(lang, 'search.label')}</span>
  <kbd
    aria-hidden="true"
    class="hidden rounded border border-[var(--border-subtle)] bg-[var(--surface)] px-1 font-mono text-[11px] text-[var(--fg-subtle)] sm:inline"
  >⌘K</kbd>
</button>

{/* Dialog */}
<div
  data-search-dialog
  role="dialog"
  aria-modal="true"
  aria-label={t(lang, 'search.dialogAriaLabel')}
  hidden
  class="fixed inset-0 z-[100] flex items-start justify-center bg-black/50 px-4 pt-[12vh] backdrop-blur-sm"
>
  <div
    data-search-panel
    class="w-full max-w-xl overflow-hidden rounded-xl border border-[var(--border-subtle)] bg-[var(--surface-raised)] shadow-2xl"
  >
    <div class="flex items-center gap-3 border-b border-[var(--border-subtle)] px-4">
      <svg aria-hidden="true" class="h-5 w-5 shrink-0 text-[var(--fg-subtle)]" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="9" cy="9" r="6"></circle>
        <path d="m14 14 4 4" stroke-linecap="round"></path>
      </svg>
      <input
        data-search-input
        type="search"
        autocomplete="off"
        spellcheck="false"
        placeholder={t(lang, 'search.placeholder')}
        aria-label={t(lang, 'search.placeholder')}
        aria-controls="search-results"
        class="w-full bg-transparent py-3.5 text-[var(--fg)] outline-none placeholder:text-[var(--fg-subtle)]"
      />
    </div>

    <div
      id="search-results"
      data-search-results
      role="listbox"
      aria-live="polite"
      class="max-h-[55vh] overflow-y-auto p-2"
    >
      <p data-search-empty class="px-3 py-6 text-center text-sm text-[var(--fg-muted)]">
        {t(lang, 'search.empty')}
      </p>
    </div>

    <div
      class="flex items-center gap-4 border-t border-[var(--border-subtle)] px-4 py-2 text-[11px] text-[var(--fg-subtle)]"
    >
      <span><kbd class="font-mono">↑↓</kbd> {t(lang, 'search.hintNavigate')}</span>
      <span><kbd class="font-mono">↵</kbd> {t(lang, 'search.hintSelect')}</span>
      <span><kbd class="font-mono">esc</kbd> {t(lang, 'search.hintClose')}</span>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    noResultsLabel: t(lang, 'search.noResults'),
    emptyLabel: t(lang, 'search.empty'),
    resultsLabel: t(lang, 'search.resultsLabel'),
  }}
>
  (function () {
    const dialog = document.querySelector('[data-search-dialog]');
    const panel = dialog?.querySelector('[data-search-panel]');
    const input = dialog?.querySelector('[data-search-input]');
    const list = dialog?.querySelector('[data-search-results]');
    const openBtn = document.querySelector('[data-search-open]');
    if (!dialog || !panel || !input || !list || !openBtn) return;

    let pagefind = null;
    let lastFocus = null;
    let active = -1;
    let items = [];
    let debounce;

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        // Built asset — absent at build time, present in dist/ and dev (served by astro-pagefind).
        pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
        await pagefind.init();
      } catch (err) {
        pagefind = null;
      }
      return pagefind;
    }

    function open() {
      lastFocus = document.activeElement;
      dialog.hidden = false;
      document.body.style.overflow = 'hidden';
      input.value = '';
      renderEmpty();
      loadPagefind();
      requestAnimationFrame(() => input.focus());
    }

    function close() {
      dialog.hidden = true;
      document.body.style.overflow = '';
      active = -1;
      items = [];
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    function renderEmpty() {
      list.innerHTML =
        '<p class="px-3 py-6 text-center text-sm text-[var(--fg-muted)]">' +
        emptyLabel +
        '</p>';
    }

    function renderNoResults(query) {
      list.innerHTML =
        '<p class="px-3 py-6 text-center text-sm text-[var(--fg-muted)]">' +
        noResultsLabel +
        ' “' +
        escapeHtml(query) +
        '”.</p>';
    }

    function escapeHtml(s) {
      return s.replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function setActive(next) {
      const links = list.querySelectorAll('[data-result]');
      if (!links.length) return;
      active = (next + links.length) % links.length;
      links.forEach((el, i) => {
        const on = i === active;
        el.setAttribute('aria-selected', on ? 'true' : 'false');
        el.classList.toggle('bg-[var(--surface-sunken)]', on);
        if (on) el.scrollIntoView({ block: 'nearest' });
      });
    }

    async function runSearch(query) {
      const pf = await loadPagefind();
      if (!pf) {
        renderNoResults(query);
        return;
      }
      const search = await pf.search(query);
      const data = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
      if (!data.length) {
        renderNoResults(query);
        return;
      }
      list.innerHTML =
        '<p class="px-3 pb-1 pt-2 text-[11px] uppercase tracking-wide text-[var(--fg-subtle)]">' +
        data.length +
        ' ' +
        resultsLabel +
        '</p>';
      data.forEach((d) => {
        const a = document.createElement('a');
        a.href = d.url;
        a.dataset.result = '';
        a.setAttribute('role', 'option');
        a.setAttribute('aria-selected', 'false');
        a.className =
          'block rounded-lg px-3 py-2 no-underline transition-colors hover:bg-[var(--surface-sunken)]';
        a.innerHTML =
          '<span class="block text-sm font-medium text-[var(--fg)]">' +
          escapeHtml(d.meta && d.meta.title ? d.meta.title : d.url) +
          '</span><span class="mt-0.5 block text-xs leading-snug text-[var(--fg-muted)]">' +
          d.excerpt +
          '</span>';
        list.appendChild(a);
      });
      items = data;
      active = -1;
    }

    openBtn.addEventListener('click', open);

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        dialog.hidden ? open() : close();
        return;
      }
      if (dialog.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(active + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(active - 1);
      } else if (e.key === 'Enter' && active >= 0) {
        const links = list.querySelectorAll('[data-result]');
        if (links[active]) {
          e.preventDefault();
          links[active].click();
        }
      }
    });

    dialog.addEventListener('click', (e) => {
      if (!panel.contains(e.target)) close();
    });

    input.addEventListener('input', () => {
      clearTimeout(debounce);
      const q = input.value.trim();
      if (!q) {
        renderEmpty();
        return;
      }
      debounce = setTimeout(() => runSearch(q), 150);
    });
  })();
</script>
