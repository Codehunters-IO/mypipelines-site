---
import { t, type Locale } from '../i18n/ui';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  variant: 'mobile' | 'desktop';
  lang: Locale;
}

const { headings, variant, lang } = Astro.props;
const summary = `${t(lang, 'toc.summary')} (${headings.length} ${t(lang, 'toc.itemsLabel')})`;
---

{
  variant === 'mobile' && (
    <details
      data-pagefind-ignore="all"
      class="my-4 rounded-lg border border-[var(--border-subtle)] surface-raised lg:hidden"
    >
      <summary class="cursor-pointer px-3 py-2 font-medium text-[var(--fg)]">{summary}</summary>
      <nav class="px-3 py-2">
        <ul class="space-y-1 text-sm">
          {headings.map((h) => (
            <li class={h.depth === 3 ? 'ml-4' : ''}>
              <a href={`#${h.slug}`} class="text-[var(--fg-muted)] hover:text-[var(--fg)]">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  )
}

{
  variant === 'desktop' && (
    <aside data-pagefind-ignore="all" class="hidden lg:block">
      <nav class="sticky top-24 max-h-[calc(100vh-6rem)] overflow-y-auto border-l border-[var(--border-subtle)] pl-4">
        <h2 class="mb-2 font-mono text-xs font-semibold uppercase tracking-wide text-[var(--fg-subtle)]">
          {t(lang, 'toc.summary')}
        </h2>
        <ul class="space-y-0.5 text-sm">
          {headings.map((h) => (
            <li class={h.depth === 3 ? 'ml-3' : ''}>
              <a
                href={`#${h.slug}`}
                data-toc-link={h.slug}
                class="toc-link block rounded py-0.5 text-[var(--fg-muted)] transition-colors hover:text-[var(--fg)]"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  // Scroll-spy for the desktop ToC. No-ops when no [data-toc-link] anchors
  // are present (i.e. mobile variant), so it is safe to render unconditionally.
  import { initScrollSpy } from '../lib/scroll-spy';
  initScrollSpy({ linkAttr: 'data-toc-link', rootMargin: '-96px 0px -70% 0px' });
</script>
