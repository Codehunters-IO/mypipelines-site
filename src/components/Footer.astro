---
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/ui';
import { REPO_URL, GITHUB_URL, LINKEDIN_URL } from '../lib/site';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;

const guidesHref = '/guides/quick-start';
const year = new Date().getFullYear();
---

<footer
  data-pagefind-ignore="all"
  class="mt-20 border-t border-[var(--border-subtle)] surface-sunken"
>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-sm">
        <span class="inline-flex items-center gap-1 font-mono text-sm font-semibold tracking-tight text-[var(--fg)]">
          <span aria-hidden="true">&gt;</span>
          {t(lang, 'home.title')}
        </span>
        <p class="mt-2 text-sm text-[var(--fg-muted)]">{t(lang, 'footer.tagline')}</p>
      </div>

      <nav class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm" aria-label="Footer">
        <a href="/actions" class="term-link">{t(lang, 'nav.actions')}</a>
        <a href={REPO_URL} target="_blank" rel="noopener" class="term-link">{t(lang, 'footer.repo')}</a>
        <a href="/gradle" class="term-link">{t(lang, 'nav.gradle')}</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="term-link">GitHub</a>
        <a href={guidesHref} class="term-link">{t(lang, 'footer.guides')}</a>
        <a href={LINKEDIN_URL} target="_blank" rel="noopener" class="term-link">LinkedIn</a>
        <a href="/reference/rulesets" class="term-link">{t(lang, 'nav.reference')}</a>
      </nav>
    </div>

    <div class="mt-8 flex flex-col gap-1 border-t border-[var(--border-subtle)] pt-6 text-xs text-[var(--fg-muted)] sm:flex-row sm:items-center sm:justify-between">
      <span>© {year} Andrés Montoya · <span class="font-mono font-semibold tracking-tight">Codehunters</span></span>
      <span class="font-mono">{t(lang, 'footer.builtWith')}</span>
    </div>
  </div>
</footer>
