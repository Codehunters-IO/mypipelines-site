---
import ThemeToggle from './ThemeToggle.astro';
import SearchModal from './SearchModal.astro';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const homeHref = '/';
const guidesHref = '/guides';
const path = Astro.url.pathname;
const guidesActive = path.includes('/guides');
---

<header
  data-pagefind-ignore="all"
  class="sticky top-0 z-50 border-b border-[var(--border-subtle)] bg-[var(--surface)]/80 backdrop-blur"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2.5">
    <a
      href={homeHref}
      class="group inline-flex items-center gap-2 rounded font-mono text-sm font-semibold tracking-tight text-[var(--fg)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
    >
      <span aria-hidden="true" class="h-2 w-2 rounded-full bg-brand-500 transition-transform group-hover:scale-125"></span>
      {t(lang, 'home.title')}
    </a>

    <div class="flex items-center gap-1 sm:gap-3">
      <a
        href={guidesHref}
        aria-current={guidesActive ? 'page' : undefined}
        class:list={[
          'rounded px-2 py-1 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500',
          guidesActive
            ? 'text-brand-600 dark:text-brand-400'
            : 'text-[var(--fg-muted)] hover:text-[var(--fg)]',
        ]}
      >
        {t(lang, 'nav.guides')}
      </a>
      <span aria-hidden="true" class="hidden h-4 w-px bg-[var(--border-subtle)] sm:block"></span>
      <SearchModal lang={lang} />
      <ThemeToggle lang={lang} />
    </div>
  </div>
</header>
