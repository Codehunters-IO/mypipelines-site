---
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const path = Astro.url.pathname;

const navLinks = [
  { href: '/', key: 'nav.pipelines' as const },
  { href: '/actions', key: 'nav.actions' as const },
  { href: '/gradle', key: 'nav.gradle' as const },
  { href: '/search', key: 'nav.search' as const },
];
---

<header
  data-pagefind-ignore="all"
  class="sticky top-0 z-50 border-b border-[var(--border-subtle)] bg-[var(--surface)]/90 backdrop-blur"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2.5">
    <a
      href="/"
      class="inline-flex items-center gap-1 font-mono text-sm font-semibold tracking-tight text-[var(--fg)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--fg)]"
    >
      <span aria-hidden="true">&gt;</span>
      {t(lang, 'home.title')}
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {navLinks.map(({ href, key }) => {
        const isActive = href === '/' ? path === '/' : path.startsWith(href);
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'term-tag px-1.5 py-1 transition-colors duration-[var(--duration-fast)] ease-[var(--ease-out)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--fg)]',
              isActive ? 'text-[var(--fg)]' : 'text-[var(--fg-muted)] hover:text-[var(--fg)]',
            ]}
          >
            {t(lang, key)}
          </a>
        );
      })}
    </nav>
  </div>
</header>
